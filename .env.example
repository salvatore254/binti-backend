# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ========== SERVER CONFIG ==========
PORT=5000
NODE_ENV=production

# ========== FRONTEND/BACKEND SEPARATION ==========
# Set these for separate frontend and backend deployment
# SERVE_FRONTEND controls if backend serves static files (only set to true in development)
SERVE_FRONTEND=false

# Frontend URL - used for CORS configuration on backend
# In development: http://localhost:3000
# In production: your frontend deployment URL (e.g., https://binti-frontend.vercel.app)
FRONTEND_URL=https://your-frontend-domain.com

# Backend API URL - frontend needs to know where backend is hosted
# Railway example: https://binti-backend-production.up.railway.app/api
BACKEND_API_URL=https://binti-backend-production.up.railway.app/api

# ========== DATABASE CONFIG ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=binti_events
DB_USER=postgres
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql://user:password@localhost:5432/binti_events

# ========== EMAIL CONFIG (for contact form) ==========
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
ADMIN_EMAIL=admin@bintievents.com

# ========== PESAPAL CONFIG ==========
# For local development without internet access to sandbox.pesapal.com:
# Set USE_PESAPAL_MOCK=true to use mock Pesapal service
# This allows testing the payment flow without network access
# When deployed to production with internet access, set USE_PESAPAL_MOCK=false
USE_PESAPAL_MOCK=false
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_API_URL=https://api.pesapal.com
PESAPAL_REDIRECT_URL=https://binti.example.com/payment-status

# ========== MPESA CONFIG ==========
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_business_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_API_URL=https://sandbox.safaricom.co.ke  # Use production URL in production
