# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# ⚠️ IMPORTANT: NEVER commit .env with real credentials to version control
# Add '.env' to .gitignore before pushing to GitHub

# ========== SERVER CONFIG ==========
PORT=5000
# Set to 'development' for local testing, 'production' for deployed servers
NODE_ENV=development

# ========== FRONTEND CONFIGURATION ==========
# The URL where your frontend is hosted (used for CORS)
# Local development: http://localhost:3000 (if using local server) or http://localhost:5500 (Live Server)
# Production: https://bintievents.vercel.app (your actual frontend domain)
FRONTEND_URL=http://localhost:3000

# ========== DATABASE CONFIG (MongoDB) ==========
# For local development (default):
DB_HOST=localhost
DB_PORT=27017
DB_NAME=binti_events
DB_USER=
DB_PASSWORD=
# For production with MongoDB Atlas or managed service:
# DATABASE_URL=mongodb+srv://username:password@cluster0.mongodb.net/binti_events
# For local MongoDB:
DATABASE_URL=mongodb://localhost:27017/binti_events


# ========== EMAIL CONFIG (SMTP) ==========
# Gmail SMTP Configuration for sending emails
# Steps to set up:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an app-specific password for "Mail" on "Windows (or other device)"
# 4. Use that password as EMAIL_PASS (NOT your regular Gmail password!)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_16_char_password
ADMIN_EMAIL=admin@bintievents.com

# ========== PESAPAL CONFIG ==========
# Pesapal Payment Gateway
# For local development (NO INTERNET): Set USE_PESAPAL_MOCK=true
#   - Uses mock service to simulate Pesapal without network access
# For production (WITH INTERNET): Set USE_PESAPAL_MOCK=false
#   - Makes real API calls to Pesapal
USE_PESAPAL_MOCK=true
# Get these credentials from: https://sandbox.pesapal.com (for testing)
PESAPAL_CONSUMER_KEY=your_pesapal_sandbox_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_sandbox_consumer_secret
# Sandbox URL for testing, production: https://api.pesapal.com
PESAPAL_API_URL=https://sandbox.pesapal.com
# Redirect URL after payment (must be accessible from internet when testing real Pesapal)
PESAPAL_REDIRECT_URL=http://localhost:5000/payment-status

# ========== MPESA CONFIG ==========
# M-Pesa Payment Gateway (Daraja API)
# Currently using SANDBOX mode for testing
# Get credentials from: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_from_daraja
MPESA_SHORTCODE=your_mpesa_business_shortcode
MPESA_PASSKEY=your_mpesa_sandbox_passkey
