# Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# Do not commit real credentials.

# ========== SERVER CONFIG ==========
PORT=5000
NODE_ENV=development
ENABLE_TEST_ENDPOINTS=true

# ========== APP URLS ==========
FRONTEND_URL=https://binti-events-backend.onrender.com
APP_URL=https://binti-events-backend.onrender.com
BACKEND_URL=https://binti-events-backend.onrender.com

# ========== DATABASE CONFIG (POSTGRESQL) ==========
# Use DATABASE_URL for managed Postgres, or leave it empty and use the PG* values.
# Example:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/binti_events
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=binti_events
PGUSER=postgres
PGPASSWORD=your_local_postgres_password
DB_SSL=false

# ========== EMAIL CONFIG ==========
# Resend is the active email provider.
RESEND_API_KEY=
EMAIL_FROM=Binti Events <onboarding@resend.dev>
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=admin@bintievents.com

# ========== PESAPAL CONFIG ==========
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_API_URL=https://cybqa.pesapal.com/pesapalv3
PESAPAL_USE_SANDBOX=true
PESAPAL_MERCHANT_REFERENCE=
PESAPAL_REDIRECT_URL=https://binti-events-backend.onrender.com
PESAPAL_CALLBACK_URL=https://binti-events-backend.onrender.com/api/payments/pesapal-callback
PESAPAL_IPN_URL=https://binti-events-backend.onrender.com/api/payments/pesapal-callback
PESAPAL_NOTIFICATION_ID=

# ========== MPESA CONFIG ==========
MPESA_PROVIDER=daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://binti-events-backend.onrender.com/api/payments/mpesa-callback
MPESA_USE_SANDBOX=true

# ========== MEXPRESS CONFIG ==========
MEXPRESS_BASE_URL=https://mexpress.co.ke
MEXPRESS_PUBLIC_KEY=
MEXPRESS_SECRET_KEY=
MEXPRESS_RETURN_URL=https://binti-events-backend.onrender.com
MEXPRESS_WEBHOOK_URL=https://binti-events-backend.onrender.com/api/payments/mexpress-callback

# ========== WHATSAPP CONFIG ==========
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=Binti_Events
ADMIN_WHATSAPP_PHONE=
